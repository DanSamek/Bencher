@using WebApplication.Components.Components
@using WebApplication.Stores
@using WebApplication.Web.Components

@page "/Tests/Passed"

@rendermode InteractiveServer

@inject TestStore TestStore

<PageTitle>Passed tests</PageTitle>
<PageHeader Value="Passed tests" />


<TestLinksPaging InitialTests="_passedTests"
                 NextPageClicked="OnNextPageClicked"
                 PreviousPageClicked="OnPreviousPageClicked">
</TestLinksPaging>

@code {
    private IReadOnlyList<Data.Models.Test> _passedTests = [];
    
    /// <inheritdoc /> 
    protected override void OnInitialized()
    {
        _passedTests = TestStore.GetPassedTestsForPage(0);
        base.OnInitialized();
    }
    
    private PageClickedResult<Data.Models.Test> OnNextPageClicked(PageClickedArgs args)
    {
        var tests = TestStore.GetPassedTestsForPage(args.RequestedPageIndex);
        var result = new PageClickedResult<Data.Models.Test>(tests);
        return result;
    }
    
    private PageClickedResult<Data.Models.Test> OnPreviousPageClicked(PageClickedArgs args)
    {
        var tests = TestStore.GetPassedTestsForPage(args.RequestedPageIndex);
        var result = new PageClickedResult<Data.Models.Test>(tests);
        return result;
    }
}
@inherits CustomComponentBase

@using WebApplication.Stores
@using WebApplication.Web.Components

@page "/Tests/Running"

@rendermode InteractiveServer

@inject TestStore TestStore

<PageTitle>Running tests</PageTitle>
<PageHeader Value="Running tests" />
    
<TestLinks Tests="_runningTests" />

@code {
    private IReadOnlyList<Data.Models.Test> _runningTests = [];
    
    /// <inheritdoc /> 
    protected override void OnInitialized()
    {
        (_, _runningTests) = TestStore.GetRunningTests();
        base.OnInitialized();
    }
}
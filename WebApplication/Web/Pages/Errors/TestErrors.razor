@code {
    private IReadOnlyList<Data.Models.TestError> _errors = [];
    
    /// <inheritdoc /> 
    protected override void OnInitialized()
    {
        _errors = TestErrorStore.GetErrorsForPage(0);
        base.OnInitialized();
    }
    
    private PageClickedResult<Data.Models.TestError> OnNextPageClicked(PageClickedArgs args)
    {
        var errors = TestErrorStore.GetErrorsForPage(args.RequestedPageIndex);
        var result = new PageClickedResult<Data.Models.TestError>(errors);
        return result;
    }
    
    private PageClickedResult<Data.Models.TestError> OnPreviousPageClicked(PageClickedArgs args)
    {
        var errors = TestErrorStore.GetErrorsForPage(args.RequestedPageIndex);
        var result = new PageClickedResult<Data.Models.TestError>(errors);
        return result;
    }
}
@page "/Errors/Tests"

@inherits CustomComponentBase

@using WebApplication.Stores
@using WebApplication.Web.Components

@rendermode InteractiveServer

@inject TestErrorStore TestErrorStore
    
<PageTitle>Test errors</PageTitle>
<PageHeader Value="Test errors"/>

@* TODO paging !! *@
<TestErrorsTable Errors="_errors" ShowTestId />

@code {
    private IReadOnlyList<Data.Models.TestError> _errors = [];
    
    /// <inheritdoc /> 
    protected override void OnInitialized()
    {
        _errors = TestErrorStore.GetErrors();
        base.OnInitialized();
    }
}
@page "/Errors/Tests"

@inherits CustomComponentBase

@using WebApplication.Components.Components
@using WebApplication.Stores
@using WebApplication.Web.Components

@rendermode InteractiveServer

@inject TestErrorStore TestErrorStore
    
<PageTitle>Test errors</PageTitle>
<PageHeader Value="Test errors"/>

<TablePaginator InitialRows="_errors"
                NextPageClicked="OnNextPageClicked"
                PreviousPageClicked="OnPreviousPageClicked" 
                AdditionalCssClass="table-striped">
    <HeaderContent>
        <thead>
            <tr>
                <th>Id</th>
                <th>Test id</th>
                <th>Datetime</th>
                <td>Log</td>
            </tr>
        </thead>
    </HeaderContent>
    
    <RowContent>
        <tr>
            <td>@context.Id</td>
            @{
                var testPath = $"/Test/{context.Test.Id}";
            }
            <td><ReloadLink Url="@testPath">@context.Test.Id</ReloadLink></td>
            
            <td>@context.Time</td>
            @{
                var fileName = $"error_{context.Time}_{context.Test.Id}";
            }
            <td><DownloadButton FileName="@fileName" DataLoader="() => TestErrorStore.LoadContent(context.Id)"/></td>
        </tr>
    </RowContent>
</TablePaginator>


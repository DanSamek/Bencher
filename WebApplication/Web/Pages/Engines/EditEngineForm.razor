@inherits AuthorizedPageBase

@using WebApplication.Data.Models
@using WebApplication.Stores
@using WebApplication.Web.Components

@inject EngineStore EngineStore

@* NOTE: Similar code in the AddEngineForm and EngineDetail. *@
@* NOTE: Engine can be edited only if no test is in the queue *@

<EditForm Model="_formData" OnSubmit="EditEngine" FormName="AddEngine">
    <DataAnnotationsValidator/>
    <div class="form-floating mb-3">
        <InputText class="form-control" @bind-Value="@_formData.Name" Id="Name" />
        <label for="Name" class="form-label">Name</label>
        <ValidationMessage For="@(() => _formData.Name)"/>
    </div>
    
    <div class="form-floating mb-3">
        <InputText class="form-control" @bind-Value="@_formData.GitUrl" Id="GitUrl"></InputText>
        <label for="GitUrl" class="form-label">Git url</label>
        <ValidationMessage For="@(() => _formData.GitUrl)"/>
    </div>
    
    <div class="form-floating mb-3 code-editor-form">
        <span>Build script</span>
        <div class="editor-box">
            <CodeEditor @ref="_codeEditor" Language="shell" InitialValue="@_formData.BuildScript" />
        </div>
        <ValidationMessage For="@(() => _formData.BuildScript)"/>
    </div>
    <button type="submit" class="btn btn-primary ms-auto d-block" value="Save">Edit</button>
</EditForm>

@code {
    private EngineFormModel _formData = null!;
    private CodeEditor _codeEditor = null!;
    
    [Parameter, EditorRequired]
    public required Action OnEngineEdit { get; set; }
    
    [Parameter, EditorRequired]
    public required Engine Engine { get; set; }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _formData = new EngineFormModel
        {
            Name = Engine.Name,
            GitUrl = Engine.GitUrl,
            BuildScript = Engine.GetBuildScriptString()
        };
    }
    
    private async Task EditEngine(EditContext context)
    {
        if (context.Model is not EngineFormModel model)
        {
            throw new Exception("Invalid form model.");
        }

        model.BuildScript = await _codeEditor.GetValue();
        if (!context.Validate())
        {
            return;
        }
        
        EngineStore.Update(Engine.Id, _formData.Name, _formData.GitUrl, _formData.BuildScript);
        OnEngineEdit.Invoke();
    }
}
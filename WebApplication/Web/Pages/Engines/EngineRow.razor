@using WebApplication.Data.Models
@using WebApplication.Stores
@using WebApplication.Web.Components

@inject EngineStore EngineStore

<tr>
    <td class="d-block d-lg-none" ><a href="@Engine.GitUrl" target="_blank">@Engine.Name</a></td>
    <td class="d-none d-lg-block" ><span>@Engine.Name</span></td>
    
    <td class="text-center"><a class="d-none d-lg-block" href="@Engine.GitUrl" target="_blank">@Engine.GitUrl</a></td>
    <td>
        <div class="d-flex gap-2 justify-content-end">
            <button type="button" class="btn btn-secondary btn-danger d-flex align-items-center gap-2" @onclick="RemoveEngine">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                    <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"></path>
                </svg>
                <span class="d-none d-sm-block">Remove</span>
            </button>
            <button type="button" class="btn btn-secondary btn d-flex align-items-center gap-2" @onclick="EditEngine">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325"></path>
                </svg>
                <span class="d-none d-sm-block">Edit</span>
            </button>
            <button type="button" class="btn btn-primary d-flex align-items-center gap-2" @onclick="ShowEngineDetail">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                </svg>
                <span class="d-none d-sm-block">Detail</span>
            </button>
        </div>
    </td>
</tr>  

<Popup @ref="_detailPopup" Title="@Engine.Name">
    <EngineDetail Engine="Engine" />
</Popup>
    
@{
    var editPopupTitle = $"{Engine.Name} (Edit)";
}
<Popup @ref="_editPopup" Title="@editPopupTitle">
    <EditEngineForm Engine="Engine" OnEngineEdit="@(() => 
                                                  { 
                                                      _editPopup?.Close();
                                                      OnEngineUpdate.Invoke();
                                                  })" />
</Popup>

@code {
    private Popup? _detailPopup;
    private Popup? _editPopup;
    
    /// <summary>
    /// An engine for row.
    /// </summary>
    [Parameter, EditorRequired]
    public required Engine Engine { get; set; }
    
    /// <summary>
    /// Action when engine is deleted.
    /// </summary>
    [Parameter, EditorRequired]
    public required Action OnEngineDelete { get; set; } 
    
    /// <summary>
    /// Action when engine has not finished test - edit.
    /// </summary>
    [Parameter, EditorRequired]
    public required Action OnAnyNotFinishedTest { get; set; }
    
    /// <summary>
    /// Action when engine is updated.
    /// </summary>
    [Parameter, EditorRequired]
    public required Action OnEngineUpdate { get; set; }
    
    private void RemoveEngine()
    {
        EngineStore.DeleteById(Engine.Id);
        OnEngineDelete.Invoke();
    }
    
    private void EditEngine()
    {
        var anyRunningTest = EngineStore.AnyNotFinishedTest(Engine.Id);
        if (anyRunningTest)
        {
            OnAnyNotFinishedTest.Invoke();
            return;
        }
        _editPopup?.Show();
    }
    
    private void ShowEngineDetail()
    {
        _detailPopup?.Show();
    }
}
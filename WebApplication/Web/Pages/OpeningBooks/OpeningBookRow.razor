@using WebApplication.Data.Models
@using WebApplication.Stores

@inject OpeningBookStore OpeningBookStore
@inject IJSRuntime JsRuntime

<tr>
    <td><span>@OpeningBook.Name</span></td>
    <td><span>@OpeningBook.Depth</span></td>
    <td><span>@OpeningBook.Type</span></td>
    
    <td>
        <div class="d-flex gap-2 justify-content-end">
            @{
                var deleteStyle = EnableDelete ?  string.Empty : "visibility: hidden;";
            }
            <button type="button" class="btn btn-secondary btn-danger d-flex align-items-center gap-2" style="@deleteStyle" @onclick="EnableDelete ? RemoveOpeningBook : () => { }">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                    <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"></path>
                </svg>
                <span class="d-none d-sm-block">Remove</span>
            </button>
        

            <button type="button" class="btn btn-secondary d-flex align-items-center gap-2" @onclick="DownloadOpeningBook">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-arrow-down" viewBox="0 0 16 16">
                    <path d="M8.5 6.5a.5.5 0 0 0-1 0v3.793L6.354 9.146a.5.5 0 1 0-.708.708l2 2a.5.5 0 0 0 .708 0l2-2a.5.5 0 0 0-.708-.708L8.5 10.293z"/>
                    <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
                </svg>
                <span class="d-none d-sm-block">Download</span>
            </button>
        </div>
    </td>
</tr>  

@code {
    /// <summary>
    /// An opening book for the row.
    /// </summary>
    [Parameter, EditorRequired]
    public required OpeningBook OpeningBook { get; set; }
    
    /// <summary>
    /// If deletion is enabled for a book.
    /// </summary>
    [Parameter, EditorRequired]
    public required bool EnableDelete { get; set; }
    
    /// <summary>
    /// Action when opening book is deleted.
    /// </summary>
    [Parameter, EditorRequired]
    public required Action OnOpeningBookDeleted { get; set; }
    
    /// <summary>
    /// Action when opening book has not finished test.
    /// </summary>
    [Parameter, EditorRequired]
    public required Action OnAnyNotFinishedTest { get; set; }

    private void RemoveOpeningBook()
    {
        var result = OpeningBookStore.AnyRunningTest(OpeningBook.Id);
        if (result)
        {
            OnAnyNotFinishedTest.Invoke();
            return;
        }
        OpeningBookStore.DeleteById(OpeningBook.Id);
        OnOpeningBookDeleted.Invoke();
    }

    private async Task DownloadOpeningBook()
    {
        var data = OpeningBookStore.LoadContent(OpeningBook.Id);
        using var memoryStream = new MemoryStream(data);
        using var streamRef = new DotNetStreamReference(stream: memoryStream);
        await JsRuntime.InvokeVoidAsync("downloadFile", OpeningBook.Name, streamRef);
    }
}
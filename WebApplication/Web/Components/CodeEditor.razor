@inherits CustomComponentBase

@if (!_initialized)
{
    <LoadingBar />
}
<div id="@Id" class="code-editor"></div>

@code {
    private bool _initialized = false;
    
    /// <summary>
    /// Language of the code editor.
    /// </summary>
    [Parameter, EditorRequired]
    public required string Language { get; set; }

    /// <summary>
    /// Initial value of the editor.
    /// </summary>
    [Parameter]
    public string? InitialValue { get; set; }
    
    /// <summary>
    /// If editor should be in the read-only mode. 
    /// </summary>
    [Parameter]
    public bool Readonly { get; set; }
    
    /// <inheritdoc /> 
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("registerMonacoEditor", [Id, Language.ToLower(), InitialValue ?? string.Empty, Readonly]);
            _initialized = true;
            StateHasChanged();
        }
    }
    
    /// <summary>
    /// Returns actual value of the editor.
    /// </summary>
    public async Task<string> GetValue()
    {
        var result = await JsRuntime.InvokeAsync<string>("getMonacoEditorText", [Id]);
        return result;
    }
    
    public Task<string> SetValue(string value)
    {
        throw new NotImplementedException();
    }
}
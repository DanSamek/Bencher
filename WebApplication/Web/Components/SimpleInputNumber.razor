@typeparam TNumber

@using System.Linq.Expressions
@inherits CustomComponentBase

@{
    var nameWithId = $"{Name}{Id}";
    var mb3Class = Mb3 ? "mb-3" : string.Empty;
}
<div class="form-floating @mb3Class">
    <InputNumber TValue="TNumber" class="form-control" ValueExpression="() => _inputValue" Value="@_inputValue" ValueChanged="OnValueChanged" Id="@nameWithId"></InputNumber>
    <label for="@nameWithId" class="form-label">@Name</label>
    <ValidationMessage For="For"/>
</div>

@code {
    private TNumber _inputValue = default!;

    /// <summary>
    /// If css class "mb-3" is added to the div.
    /// </summary>
    [Parameter]
    public bool Mb3 { get; set; } = true;
    
    /// <summary>
    /// Input name.
    /// </summary>
    [EditorRequired, Parameter]
    public required string Name { get; set; }
    
    /// <summary>
    /// Callback, when value of the input is changed.
    /// </summary>
    [EditorRequired, Parameter]
    public required EventCallback<TNumber> ValueChanged { get; set; }
    
    /// <summary>
    /// Initial value of the editor.
    /// </summary>
    [EditorRequired, Parameter]
    public required TNumber Value { get; set; }
    
    /// <summary>
    /// <see cref="ValidationMessage{TValue}.For"/>
    /// </summary>
    [EditorRequired, Parameter]
    public required Expression<Func<TNumber>> For { get; set; }
    
    protected override void OnParametersSet()
    {
        _inputValue = Value;
    }

    private async Task OnValueChanged(TNumber value)
    {
        _inputValue = value;
        await ValueChanged.InvokeAsync(_inputValue);
    }
}
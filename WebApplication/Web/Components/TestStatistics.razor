@using WebApplication.SPRT
@inherits CustomComponentBase

@Statistics()

@code {
    /// <summary>
    /// Test entity, that will be used to display information.
    /// </summary>
    [EditorRequired, Parameter]
    public required Data.Models.Test Test { get; set; }
    
    /// <summary>
    /// CSS width.
    /// </summary>
    [Parameter]
    public string? Style { get; set; }
    
    /// <summary>
    /// If statistics are rendered in the detail [test page] 
    /// </summary>
    [Parameter]
    public bool Detail { get; set; }
    
    private RenderFragment Statistics()
     {  
         var wdl = Test.Penta.ToWdl();
         var statistics = Sprt.GetStatistics(Test);
         var rawPenta = Test.Penta.ToRawPentanomial();
         
         var statusClass = statistics.Result switch
         {
             Sprt.SprtResult.H0Rejected => "passed",
             Sprt.SprtResult.H0NotRejected => "failed",
             _ => "unknown"
         };
         
         RenderFragment rf = @<text>
                                  <code class="text-center @statusClass" id="@Id" style="@Style">
                                      LLR: @statistics.Llr.ToString("F2") @Test.Settings.ToString()<br />
                                      @if (Detail)
                                      {
                                          <text>
                                              Elo: @statistics.Elo.ToString("F2") (-@statistics.EloLowerBound.ToString("F2"), +@statistics.EloUpperBound.ToString("F2"))<br/>
                                          </text>
                                      }
                                      WDL: [@wdl.W, @wdl.L, @wdl.D] <br/>
                                      Penta: [@rawPenta.Ll, @rawPenta.Ld, @rawPenta.Dd, @rawPenta.Wd, @rawPenta.Ww]
                                  </code>
                              </text>;
         return rf;
     }
}